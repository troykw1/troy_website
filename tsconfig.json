{
  "compilerOptions": {
    /* File Layout */
    "rootDir": "./src",                          
    "outDir": "./dist",                          

    /* Environment Settings */
    "target": "ES2020",                          
    "module": "commonjs",                        
    "lib": ["ES2020"],
    "types": ["node"],
    "esModuleInterop": true,                     
    "forceConsistentCasingInFileNames": true,    

    /* Other Outputs */
    "sourceMap": true,
    "declaration": true,

    /* Recommended Options */
    "strict": true,
    "skipLibCheck": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}